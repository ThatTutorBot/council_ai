# Required: API key sent to the configured endpoint (OpenAI API key, or LiteLLM proxy key/virtual key).
OPENAI_API_KEY="sk-..."
PORT="3001"

# Optional — when onboarding reads server env: skip setup UI and go straight to “Meet the Council”.
# LLM_VENDOR_ADVISOR="gemini"
# GEMINI_API_KEY="your-gemini-key"

# Models — raw strings passed through to the endpoint.
# With LiteLLM, use names your proxy understands (e.g. gemini/gemini-2.0-flash, anthropic/claude-3-5-sonnet-latest).
OPENAI_MODEL_FAST="gpt-4.1-mini"
OPENAI_MODEL_DECIDE="gpt-4.1-mini"
# OPENAI_DEFAULT_MODEL="gpt-4.1-mini"

# Optional: LiteLLM (or any OpenAI-compatible proxy). Same SDK; points the HTTP client at your proxy.
# Example: http://127.0.0.1:4000/v1  (match your LiteLLM `--host` / docs)
# LITELLM_BASE_URL="http://127.0.0.1:4000/v1"
# Alias:
# OPENAI_BASE_URL="http://127.0.0.1:4000/v1"

# When using a proxy: default is Chat Completions (`useResponses: false`). Set true if your proxy exposes Responses API.
# LITELLM_USE_RESPONSES="false"

# Optional: HoneyHive LLM observability
HONEYHIVE_API_KEY="hh_your_honeyhive_api_key"
HONEYHIVE_PROJECT="Great Council"
HONEYHIVE_SOURCE="dev"
