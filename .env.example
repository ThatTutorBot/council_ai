# =============================================================================
# LLM vendors (no LiteLLM required for multi-provider)
# - LLM_VENDOR_ADVISOR / LLM_VENDOR_DECIDE: openai | gemini | anthropic
# - LLM_VENDOR: default for both if the per-route vars are unset
# When required keys for the chosen vendors are set in .env.local, onboarding can skip the
# setup UI and go straight to Meet the Council (see server env validation).
# =============================================================================
LLM_VENDOR_ADVISOR="openai"
LLM_VENDOR_DECIDE="openai"
# LLM_VENDOR="openai"

# --- OpenAI (Agents SDK) OR LiteLLM in front of OpenAI-compatible API ---
# With LiteLLM: set LITELLM_BASE_URL + LITELLM_API_KEY (or OPENAI_API_KEY as the proxy token)
# Direct OpenAI only: OPENAI_API_KEY=sk-... and leave LITELLM_BASE_URL unset
OPENAI_API_KEY=""
LITELLM_API_KEY=""
LITELLM_BASE_URL=""
# OPENAI_BASE_URL=""
OPENAI_MODEL_FAST="gpt-4.1-mini"
OPENAI_MODEL_DECIDE="gpt-4.1-mini"
# OPENAI_DEFAULT_MODEL=""
# LITELLM_USE_RESPONSES="false"

# --- Google Gemini (native @google/genai) — set GEMINI_API_KEY when advisor or decide uses gemini ---
# Model ids must match https://ai.google.dev/gemini-api/docs/models — preview/experimental names often 404 (e.g. use gemini-2.5-flash, not *-preview).
GEMINI_API_KEY=""
GEMINI_MODEL_FAST="gemini-2.0-flash"
GEMINI_MODEL_DECIDE="gemini-2.0-flash"
# GEMINI_MODEL=""

# --- Anthropic Claude (native @anthropic-ai/sdk) — set ANTHROPIC_API_KEY when advisor or decide uses anthropic ---
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL_FAST="claude-3-5-sonnet-20241022"
ANTHROPIC_MODEL_DECIDE="claude-3-5-sonnet-20241022"
# Examples: claude-3-opus-20240229, claude-sonnet-4-20250514 (use IDs from Anthropic docs)
# ANTHROPIC_MODEL=""

# API: allow POST /api/setup/llm from outside localhost (only if you understand the risk)
# COUNCIL_ALLOW_SETUP_API="true"

PORT="3001"

# Optional: HoneyHive LLM observability
HONEYHIVE_API_KEY="hh_your_honeyhive_api_key"
HONEYHIVE_PROJECT="Great Council"
HONEYHIVE_SOURCE="dev"
