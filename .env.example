# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
PORT="3001"
GEMINI_MODEL_FAST="gemini-3-flash-preview"
GEMINI_MODEL_DECIDE="gemini-3-flash-preview"

# Optional: HoneyHive LLM observability
HONEYHIVE_API_KEY="hh_your_honeyhive_api_key"
HONEYHIVE_PROJECT="Great Council"
HONEYHIVE_SOURCE="dev"
